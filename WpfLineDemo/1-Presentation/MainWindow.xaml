<Window x:Class="WpfLineDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mind Map - New project" Height="800" Width="1600"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">

    <Canvas Name="MyCanvas" Background="White"
            MouseLeftButtonDown="MyCanvas_MouseLeftButtonDown">
        <Button x:Name="ArrowButton"
            Width="28"
            Height="28"
            Click="ArrowButton_Click">
            <TextBlock Text="➜" FontSize="16" />
        </Button>
    </Canvas>

</Window>